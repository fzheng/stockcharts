# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Redis (optional — falls back to in-memory cache)
REDIS_URL=

# Twelve Data API key (free at https://twelvedata.com — 8 req/min, 800 req/day)
# Works without a key using "demo" mode, but sign up for better limits.
STOCK_API_KEY=

# Cache TTL in seconds (default: 8 hours)
CACHE_TTL=28800
